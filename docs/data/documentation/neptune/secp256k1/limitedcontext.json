pe":"text","text":"public-key operations."}]}]}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important limitations:"}]}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Cannot be used for operations involving secret keys, such as signing","type":"text"},{"text":" ","type":"text"},{"text":"or generating public","type":"text"},{"text":" ","type":"text"},{"text":"keys from secret keys.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Cannot be randomized or destroyed (it’s a static, shared context).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Should only be used for verification-only use cases where no secret","type":"text"},{"text":" ","type":"text"},{"text":"keys are involved.","type":"text"}]}]}]},{"inlineContent":[{"text":"This context automatically performs a self-test before use to detect","type":"text"},{"text":" ","type":"text"},{"text":"serious usage errors","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(e.g., wrong endianness compilation)."}],"type":"paragraph"}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/Neptune\/documentation\/Neptune\/SECP256K1\/limitedContext","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Neptune"}],"roleHeading":"Type Property","externalID":"s:7Neptune9SECP256K1C14limitedContextACvpZ","symbolKind":"property","role":"symbol","title":"limitedContext","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"limitedContext","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SECP256K1","preciseIdentifier":"s:7Neptune9SECP256K1C","kind":"typeIdentifier"}]},"abstract":[{"type":"text","text":"Returns a static context after performing self-test"}],"hierarchy":{"paths":[["doc:\/\/Neptune\/documentation\/Neptune","doc:\/\/Neptune\/documentation\/Neptu