n’t require heap allocation,"},{"type":"text","text":" "},{"type":"text","text":"making it suitable for environments with memory constraints or where avoiding "},{"type":"codeVoice","code":"malloc"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"free"},{"type":"text","text":" "},{"type":"text","text":"is desirable."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Read-only operations","type":"text"}]},{"type":"text","text":": Suitable for operations that don’t involve secret keys, such as:"},{"type":"text","text":" "},{"type":"text","text":"signature verification, public key parsing\/serialization, and other public-key operations."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Important limitations:"}],"type":"strong"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Cannot be used for operations involving secret keys, such as signing or generating public"},{"type":"text","text":" "},{"type":"text","text":"keys from secret keys."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Cannot be randomized or destroyed (it’s a static, shared context)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Should only be used for verification-only use cases where no secret keys are involved."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"This context automatically performs a self-test before use to detect serious usage errors","type":"text"},{"text":" ","type":"text"},{"text":"(e.g., wrong endianness compilation).","type":"text"}]}],"kind":"content"}],"references":{"doc://Neptune/documentation/Neptune/SECP256K1/limitedContext":{"title":"limitedContext","abstract":[{"type":"text","text":"Returns a static context after performing self-test"}],"role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text"