{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The context is an opaque data structure that stores:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Randomization data"}]},{"type":"text","text":" (primary purpose): Blinding values used for"},{"type":"text","text":" "},{"type":"text","text":"side-channel"},{"type":"text","text":" "},{"type":"text","text":"protection during elliptic curve operations involving secret keys"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Precomputation tables","type":"text"}]},{"type":"text","text":": Optimized lookup tables for elliptic curve"},{"type":"text","text":" "},{"type":"text","text":"point"},{"type":"text","text":" "},{"type":"text","text":"multiplications with the generator point (G)"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Error callbacks"}],"type":"strong"},{"type":"text","text":": Function pointers for handling illegal arguments"},{"type":"text","text":" "},{"type":"text","text":"and errors"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"What randomization does:","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"Randomization uses a 32-byte seed to generate secret blinding values"},{"type":"text","text":" "},{"type":"text","text":"that mask"},{"type":"text","text":" "},{"type":"text","text":"internal computations. This makes operations like signing and public key"},{"type":"text","text":" "},{"text":"generation","type":"text"},{"text":" ","type":"text"},{"text":"resistant to side-channel attacks (power analysis, timing attacks,","type":"text"},{"text":" ","type":"text"},{"text":"electromagnetic","type":"text"},{"type":"text","text":" "},{"type":"text","text":"leakage) by ensuring that the internal computation patterns are"},{"type":"text","text":" "},{"type":"text","text":"independent of the"},{"type":"text","text":" "},{"type":"text","text":"secret key values. Specifically, the seed is used to blind scalar"},{"type":"text","text":" "},{"type":"text","text":"multiplications"},{"type":"text","text":" "},{"type":"text","text":"with the base point, transforming operations like "},{"code":"R = gn*G","type":"codeVoice"},{"type":"text","text":" into "},{"code":"R = (gn - b)*G + b*G","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"where "},{"code":"b","type":"codeVoice"},{"type":"text","text":" is a secret random blinding value."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Multi-threading:"}],"type":"strong"},{"text":" ","type":"text"},{"text":"A constructed context can safely be used from multiple threads","type":"text"},{"text":" ","type":"text"},{"text":"simultaneously for","type":"text"},{"text":" ","type":"text"},{"text":"read-only operations. However, operations that modify the context (like","type":"text"},{"text":" ","type":"text"},{"text":"randomization","type":"text"},{"text":" ","type":"text"},{"text":"or destruction) require exclusive access. Since this initializer","type":"text"},{"text":" ","type":"text"},{"text":"randomizes the context","type":"text"},{"text":" ","type":"text"},{"text":"at creation time, no additional locking is needed for subsequent","type":"text"},{"text":" ","type":"text"},{"text":"read-only operations","type":"text"},{"text":" ","type":"text"},{"text":"across threads. If you need to re-randomize the context later, use","type":"text"},{"text":" ","type":"text"},{"text":"appropriate","type":"text"},{"text":" ","type":"text"},{"text":"synchronization (e.g., a read-write lock) to coordinate access.","type":"text"}]},{"style":"note","name":"Throws","content":[{"inlineContent":[{"type":"text","text":"SECPError.randomGenerationFailed if secure random bytes cannot"},{"type":"text","text":" "},{"type":"text","text":"be generated"},{"type":"text","text":" "},{"type":"text","text":"or if the provided seed is not exactly 32 bytes"}],"type":"paragraph"}],"type":"aside"},{"style":"note","name":"Throws","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"SECPError.contextRandomizationFailed if context randomization"},{"type":"text","text":" "},{"type":"text","text":"fails"}]}],"type":"aside"}]}],"references":{"doc://Neptune/documentation/Neptune":{"kind":"symbol","identifier":"doc:\/\/Neptune\/documentation\/Neptune","type":"topic","role":"collection","abstract":[],"url":"\/documentation\/neptune","title":"Neptune"},"doc://Neptune/documentation/Neptune/SECP256K1":{"role":"symbol","abstract":[{"text":"A class for performing SECP256K1 elliptic curve operations","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SECP256K1"}],"identifier":"doc:\/\/Neptune\/documentation\/Neptune\/SECP256K1","type":"topic","title":"SECP256K1","url":"\/documentation\/neptune\/secp256k1","navigatorTitle":[{"kind":"identifier","text":"SECP256K1"}]},"doc://Neptune/documentation/Neptune/SECP256K1/init(seed:)":{"kind":"symbol","identifier":"doc:\/\/Neptune\/documentation\/Neptune\/SECP256K1\/init(seed:)","type":"topic","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"seed","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":"]?) ","kind":"text"},{"text":"throws","kind":"keyword"}],"abstract":[{"text":"Creates and randomizes a new SECP256K1 context","type":"text"}],"url":"\/documentation\/neptune\/secp256k1\/init(seed:)","title":"init(seed:)"}}}